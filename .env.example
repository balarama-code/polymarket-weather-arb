# Polymarket Live Trading Credentials
# Copy this file to .env and fill in your values

# Your Polygon wallet private key (from MetaMask: Account → Export Private Key)
POLY_PRIVATE_KEY=

# API credentials (from polymarket.com → Settings → API Keys → Create)
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Max position size in USD
MAX_POSITION_SIZE=5.0
